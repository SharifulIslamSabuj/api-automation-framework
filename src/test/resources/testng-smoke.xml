<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite" parallel="methods" thread-count="3">

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="com.grocery.store.api.tests.api.CartApiTest"/>
            <class name="com.grocery.store.api.tests.api.ClientApiTest"/>
            <class name="com.grocery.store.api.tests.api.ProductApiTest"/>
            <class name="com.grocery.store.api.tests.api.StatusApiTest"/>
            <class name="com.grocery.store.api.tests.e2e.OrderE2ETest"/>
        </classes>

    </test>

</suite>