<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Grocery Store API - Class Suite" parallel="classes" thread-count="3">

    <!-- ================= API TESTS ================= -->
    <test name="API Tests">
        <classes>
            <class name="com.grocery.store.api.tests.api.StatusApiTest"/>
            <class name="com.grocery.store.api.tests.api.ProductApiTest"/>
            <class name="com.grocery.store.api.tests.api.CartApiTest"/>
            <class name="com.grocery.store.api.tests.api.OrderApiTest"/>
            <class name="com.grocery.store.api.tests.api.ClientApiTest"/>
        </classes>
    </test>

    <!-- ================= E2E TESTS ================= -->
    <test name="E2E Tests">
        <classes>
            <class name="com.grocery.store.api.tests.e2e.GroceryStoreApiTest"/>
        </classes>
    </test>

</suite>